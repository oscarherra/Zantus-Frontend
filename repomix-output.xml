  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

/* ── Formularios ── */
.form-grid {
  display: grid;
  gap: 20px;
  min-width: 0;
}

.form-grid.two {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.label {
  display: flex;
  flex-direction: column;
  gap: 8px;
  font-size: 0.875rem;
  font-weight: 600;
  color: var(--color-text-primary);
