.btn:disabled {
  opacity: 0.7;
  cursor: not-allowed;
}

.btn-primary {
  background-color: var(--color-brand);
  color: #fff;
}

.btn-primary:hover:not(:disabled) {
  background-color: var(--color-brand-hover);
  box-shadow: var(--shadow-sm);
}

.btn-secondary {
  background-color: var(--color-bg-surface);
  color: var(--color-text-primary);
  border: 1px solid var(--color-border);
}

.btn-secondary:hover:not(:disabled) {
  background-color: #f4f4f5;
}

.btn-block {
  width: 100%;
}

/* ── Alertas ── */
.success-box {
  background-color: var(--color-success-alpha);
  color: #047857;
  padding: 14px 16px;
  border-radius: var(--radius-md);
  font-size: 0.875rem;
  border: 1px solid rgba(16, 185, 129, 0.2);
  overflow-wrap: break-word;
}

.error-box {
  background-color: var(--color-danger-alpha);
  color: #b91c1c;
  padding: 14px 16px;
  border-radius: var(--radius-md);
  font-size: 0.875rem;
  border: 1px solid rgba(239, 68, 68, 0.2);
  overflow-wrap: break-word;
}

/* ── Empty State ── */
.empty-state {
  padding: 40px 24px;
  text-align: center;
  color: var(--color-text-secondary);
  font-size: 0.9rem;
}

/* ════════════════════════════
   RESPONSIVE BREAKPOINTS
   ════════════════════════════ */

/* Desktop grande */
@media (min-width: 1024px) {
  .login-visual {
    display: flex;
  }
}

/* Laptop / tablet grande — grid 2 col colapsa a 1 */
@media (max-width: 1280px) {
  .layout-header {
    padding: 0 20px;
  }

  .layout-content {
    padding: 24px 20px;
  }

  .content-container {
    gap: 20px;
  }

  .grid-2,
  .form-grid.two {
    grid-template-columns: 1fr;
  }

  /* KPIs: 2 columnas en tablet */
  .kpi-row {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

/* Tablet */
@media (max-width: 768px) {
  .layout-header {
    min-height: 64px;
    padding: 0 16px;
  }

  .layout-content {
    padding: 16px;
  }

  .content-container {
    gap: 16px;
  }

  .grid,
  .kpi-row {
    gap: 12px;
  }

  .panel-header,
  .panel-body {
    padding: 16px;
  }

  .table th,
  .table td {
    padding: 10px 12px;
    font-size: 0.82rem;
  }

  .stat-card {
    padding: 16px;
  }

  .stat-value {
    font-size: 1.25rem;
  }

  .stat-icon {
    width: 38px;
    height: 38px;
  }
}

/* Mobile — KPIs 2x2, grids 1 col */
@media (max-width: 640px) {
  .layout-header {
    padding: 0 14px;
    min-height: 60px;
  }

  .layout-content {
    padding: 12px;
  }

  .content-container {
    gap: 12px;
  }

  .panel-header,
  .panel-body {
    padding: 14px;
  }

  .panel-title {
    font-size: 1rem;
  }

  .panel-subtitle,
  .muted {
    font-size: 0.8rem;
  }

  .input,
  .select,
  .textarea,
  .form-input {
    padding: 10px 12px;
    font-size: 0.9rem;
  }

  .table th,
  .table td {
    padding: 9px 10px;
  }

  /* KPIs: 2 columnas en móvil (grid 2x2) */
  .kpi-row {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 10px;
  }

  .stat-card {
    padding: 14px 12px;
    flex-direction: column;
    align-items: flex-start;
    gap: 10px;
  }

  .stat-value {
    font-size: 1.1rem;
  }

  .stat-icon {
    width: 34px;
    height: 34px;
  }

  .row-between {
    flex-direction: column;
    align-items: stretch;
    gap: 10px;
  }

  .grid-2,
  .form-grid.two {
    grid-template-columns: 1fr;
  }
}

/* Mobile muy pequeño */
@media (max-width: 380px) {
  .stat-value {
    font-size: 0.95rem;
  }

  .stat-label {
    font-size: 0.72rem;
  }
}
